# Per-machine paths — the ONE place to edit. Copy to paths.env, set for this machine, then:
#   source paths.env
# (paths.env is gitignored; this .example is committed.)

# nuScenes dataset root: the directory that contains samples/ sweeps/ maps/ v1.0-trainval/ ...
export NUSCENES_ROOT="/ABSOLUTE/PATH/TO/nuscenes"

# Where generated outputs are WRITTEN. Needs ~1.2 TB free and should be on FAST LOCAL NVMe
# (the temporal-accumulation step does millions of small random reads; a slow/network disk
# will erase the multi-GPU speedup).
export NUSCENES_EXTRA_ROOT="/ABSOLUTE/PATH/TO/nuscenes_extra"

# Number of GPUs to run in parallel.
export NUM_GPUS=5

# Optional: if `pixi` is not on your PATH, point at it explicitly (used by the launcher).
# export PIXI="$HOME/.pixi/bin/pixi"
